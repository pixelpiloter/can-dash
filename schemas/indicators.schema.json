{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Indicators Configuration Schema",
  "description": "Indicator light definition schema for can-dash",
  "type": "object",
  "required": ["indicators"],
  "properties": {
    "indicators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_]*$",
            "description": "Unique indicator ID referenced by alarm_rules.yaml actions"
          },
          "type": {
            "type": "string",
            "enum": ["light", "text", "image"]
          },
          "image_on": {
            "type": "string",
            "description": "Image file shown when indicator is active"
          },
          "image_off": {
            "type": "string",
            "description": "Image file shown when indicator is inactive"
          },
          "size": {
            "type": "object",
            "properties": {
              "width": { "type": "integer", "minimum": 1 },
              "height": { "type": "integer", "minimum": 1 }
            }
          },
          "position": {
            "type": "object",
            "properties": {
              "x": { "type": "integer" },
              "y": { "type": "integer" }
            }
          },
          "flash_on_fault": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
